model Service {
  id            String @id @default(uuid())
  title         String
  description   String
  price         Float
  status        ServiceStatus @default(AVAILABLE)

  categoryId    String
  technicianId  String

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  technician User     @relation("UserServices", fields: [technicianId], references: [id], onDelete: Cascade)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}